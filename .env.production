# Production Environment Variables for UJRIS v3
# Copy this to .env in your production environment

# Stripe Configuration (Get from https://dashboard.stripe.com)
VITE_STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_live_...

# Stripe Product Price IDs (Create in Stripe Dashboard)
STRIPE_JUSTICE_MONTHLY=price_1TEwJLI4LP1XfouYsI4BeSHZ
STRIPE_JUSTICE_ANNUAL=price_1TEwM9I4LP1XfouYNB8Ch9MU
STRIPE_SOVEREIGN_MONTHLY=price_1TEwNVI4LP1XfouY8ZSCXZQS
STRIPE_SOVEREIGN_ANNUAL=price_1TEwOJI4LP1XfouYxBACkjQp
STRIPE_ADVOCATE=price_1TEwR2I4LP1XfouYCfK25AVA

# Anthropic Claude API (Get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Application Configuration
BASE_URL=https://app.ujris.co.uk
PORT=3000

# Supabase (Get from https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://app.ujris.co.uk,https://www.ujris.co.uk